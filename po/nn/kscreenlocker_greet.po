#: fallbacktheme/Greeter.qml:58
msgid "Warning: Caps Lock on"
msgstr "Åtvaring: «Caps Lock» er på"

#: fallbacktheme/Greeter.qml:74
msgid "The session is locked"
msgstr "Økta er låst"

#: fallbacktheme/Greeter.qml:75
msgid "The session has been locked by %1"
msgstr "Økta vart låst av %1"

#: fallbacktheme/Greeter.qml:99
msgid "(or place your fingerprint on the reader)"
msgstr "(eller set fingeren på avlesaren)"

#: fallbacktheme/Greeter.qml:105
msgid "(or use your smartcard)"
msgstr "(eller set inn smartkortet ditt)"

#: fallbacktheme/Greeter.qml:114
msgid "&Switch Users"
msgstr "&Byt brukarar"

#: fallbacktheme/Greeter.qml:121
msgid "Un&lock"
msgstr "&Lås opp"

#: fallbacktheme/Greeter.qml:133
msgid "Unlocking failed"
msgstr "Klarte ikkje låsa opp"

#: main.cpp:123
#, kde-format
msgid "Greeter for the KDE Plasma Workspaces Screen locker"
msgstr "Velkomstbilete for skjermlåsar for KDE Plasma-arbeidsområde"

#: main.cpp:127
#, kde-format
msgid "Starts the greeter in testing mode"
msgstr "Startar velkomstbiletet i testmodus"

#: main.cpp:130
#, kde-format
msgid "Starts the greeter with the selected shell theme (only in Testing mode)"
msgstr "Startar velkomstbiletet med det valde skaltemaet (berre i testmodus)"

#: main.cpp:134
#, kde-format
msgid "Lock immediately, ignoring any grace time etc."
msgstr "Låser med ein gong, utan å ta omsyn til ventetid e.l."

#: main.cpp:136
#, kde-format
msgid "Delay till the lock user interface gets shown in milliseconds."
msgstr "Forseinking i millisekund til låsarbiletet vert vist."

#: main.cpp:139
#, kde-format
msgid "Don't show any lock user interface."
msgstr "Ikkje vis noko låsarbilete."

#: main.cpp:141
#, kde-format
msgid "File descriptor for connecting to ksld."
msgstr "Filskildring for kopling til ksld."
